# ── Alphaclaw core ──────────────────────────────────────────────
PORT=3000
ALPHACLAW_ROOT_DIR=

# GitHub (required by alphaclaw for workspace sync)
GITHUB_TOKEN=
GITHUB_WORKSPACE_REPO=your-org/your-repo

# ── Supabase ─────────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Dodo Payments ────────────────────────────────────────────────
DODO_API_KEY=
DODO_WEBHOOK_SECRET=
DODO_PRODUCT_ID=
DODO_ENV=test_mode
TRIAL_DAYS=7
APP_URL=http://localhost:3000

# ── OpenRouter (server-side only) ────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
CHAT_MODEL=google/gemini-2.5-flash

# ── Twilio (number purchasing) ───────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ── Vapi (voice assistant) ───────────────────────────────────────
VAPI_API_KEY=
# Vapi built-in voice IDs (cheapest: ~$0.02/min vs $0.10/min on 11labs)
# Options: Elliot, Rohan, Lily, Hana, Savannah, Cole, Harry, Paige, Spencer
VAPI_VOICE_STRAIGHTFORWARD=Elliot
VAPI_VOICE_UNHINGED=Cole

# ── Resend (email out + inbound parsing) ─────────────────────────
RESEND_API_KEY=
RESEND_FROM=Q <welcome@useq.ai>
RESEND_INBOUND_SECRET=                 # set this header to verify inbound webhook

# ── Branding ─────────────────────────────────────────────────────
AI_EMAIL_DOMAIN=jerome.ai

# ── Analytics (optional) ─────────────────────────────────────────
PLAUSIBLE_DOMAIN=                      # e.g. useq.ai

# ── Rate limits (token-based, tiered) ────────────────────────────
# Caps tuned so max monthly COGS per Pro user is under $13 on Haiku 4.5:
# $2 number + $4.90 voice + $2.31 tokens + $2.93 SMS + $0.20 email = $12.34
# Free tier has no Vapi number — LLM-only, tiny caps.
PLAN_FREE_TOKENS_DAILY=2000
PLAN_FREE_VOICE_SECONDS_DAILY=30
PLAN_FREE_SMS_DAILY=3
PLAN_FREE_EMAILS_DAILY=5
PLAN_FREE_MESSAGES_DAILY=20

# Pro tier ($20/mo subscriber)
PLAN_PRO_TOKENS_DAILY=35000
PLAN_PRO_VOICE_SECONDS_DAILY=140
PLAN_PRO_SMS_DAILY=13
PLAN_PRO_EMAILS_DAILY=50
PLAN_PRO_MESSAGES_DAILY=200

# Legacy single cap (kept for backwards compat with old code paths)
DAILY_MESSAGE_LIMIT=500
