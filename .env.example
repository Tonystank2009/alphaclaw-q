# ── Alphaclaw core ──────────────────────────────────────────────
PORT=3000
ALPHACLAW_ROOT_DIR=

# GitHub (required by alphaclaw for workspace sync)
GITHUB_TOKEN=
GITHUB_WORKSPACE_REPO=your-org/your-repo

# ── Supabase ─────────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Dodo Payments ────────────────────────────────────────────────
DODO_API_KEY=
DODO_WEBHOOK_SECRET=
DODO_PRODUCT_ID=
DODO_ENV=test_mode
TRIAL_DAYS=7
APP_URL=http://localhost:3000

# ── OpenRouter (server-side only) ────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
CHAT_MODEL=google/gemini-2.5-flash

# ── Twilio (number purchasing) ───────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ── Vapi (voice assistant) ───────────────────────────────────────
VAPI_API_KEY=
# Optional: voice IDs for each personality (ElevenLabs IDs)
VAPI_VOICE_CHILL=burt
VAPI_VOICE_SHARP=marissa
VAPI_VOICE_WARM=paige
VAPI_VOICE_FUNNY=neha

# ── Resend (email out + inbound parsing) ─────────────────────────
RESEND_API_KEY=
RESEND_FROM=Q <welcome@useq.ai>
RESEND_INBOUND_SECRET=                 # set this header to verify inbound webhook

# ── Branding ─────────────────────────────────────────────────────
AI_EMAIL_DOMAIN=jerome.ai

# ── Analytics (optional) ─────────────────────────────────────────
PLAUSIBLE_DOMAIN=                      # e.g. useq.ai

# ── Rate limits ──────────────────────────────────────────────────
DAILY_MESSAGE_LIMIT=500
